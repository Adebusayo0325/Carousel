{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@apexmint/core": ["packages/core/src/index.ts"],
      "@apexmint/core/*": ["packages/core/src/*"],
      "@apexmint/crypto": ["packages/crypto/src/index.ts"],
      "@apexmint/access-keys": ["packages/access-keys/src/index.ts"],
      "@apexmint/contract-intel": ["packages/contract-intel/src/index.ts"],
      "@apexmint/risk-engine": ["packages/risk-engine/src/index.ts"],
      "@apexmint/rpc-manager": ["packages/rpc-manager/src/index.ts"],
      "@apexmint/chains": ["packages/chains/src/index.ts"],
      "@apexmint/db": ["packages/db/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/test/**/*.ts", "apps/*/src/**/*.ts", "apps/*/test/**/*.ts"]
}
